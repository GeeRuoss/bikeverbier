---
// Bouton pilule signature : texte + pastille ronde avec flèche ↗ (cf. DESIGN.md).
interface Props {
  href: string;
  label: string;
  variant?: 'light' | 'dark' | 'teal';
  external?: boolean;
  class?: string;
}
const { href, label, variant = 'light', external = false, class: cls = '' } = Astro.props;
const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
---

<a href={href} class={`btn btn--${variant} ${cls}`} target={target} rel={rel}>
  <span>{label}</span>
  <span class="btn__dot" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M4 12 12 4M6 4h6v6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</a>
