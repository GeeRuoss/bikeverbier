---
import { pathFor, type Lang, type RouteKey } from '../data/site';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
  routeKey: RouteKey;
}
const { lang, routeKey } = Astro.props;
const ui = t(lang);
const homeHref = pathFor('home', lang);
const cta = lang === 'fr' ? 'Réserver' : 'Book';

// Contact passe en bouton CTA → on le retire des liens.
const navItems: RouteKey[] = ['guide', 'entreprise', 'semaine', 'nepal'];
---

<header class="nav" data-nav>
  <div class="nav__inner">
    <a class="brand" href={homeHref} aria-label="Bikeverbier.ch — accueil">
      <img class="brand__logo" src="/brand/logo.svg" alt="Bikeverbier.ch" width="104" height="40" />
    </a>

    <button class="burger" aria-label="Menu" aria-expanded="false" data-burger>
      <span></span><span></span><span></span>
    </button>

    <nav class="nav__menu" data-menu>
      <ul class="nav__links">
        {
          navItems.map((key) => (
            <li>
              <a href={pathFor(key, lang)} aria-current={key === routeKey ? 'page' : undefined}>
                {ui.nav[key]}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="nav__right">
        <div class="lang" role="group" aria-label="Language">
          <a href={pathFor(routeKey, 'fr')} aria-current={lang === 'fr' ? 'true' : undefined}>FR</a>
          <span aria-hidden="true">/</span>
          <a href={pathFor(routeKey, 'en')} aria-current={lang === 'en' ? 'true' : undefined}>EN</a>
        </div>
        <a class="nav__cta" href={pathFor('contact', lang)}>{cta}</a>
      </div>
    </nav>
  </div>
</header>

<style>
  /* Barre flottante en pilule, translucide + flou (style moderne). */
  .nav {
    position: fixed;
    top: clamp(0.6rem, 1.5vw, 1.1rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    width: min(1180px, calc(100% - 1.4rem));
    border-radius: var(--radius-pill);
    background: rgba(18, 20, 22, 0.5);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    backdrop-filter: blur(16px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .nav.is-solid {
    background: rgba(10, 11, 12, 0.82);
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.3);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 0.55rem 0.5rem 1.4rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
  }
  .brand__logo {
    height: 36px;
    width: auto;
    display: block;
  }
  .nav__menu {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav__links {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }
  .nav__links a {
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }
  .nav__links a:hover,
  .nav__links a[aria-current='page'] {
    color: var(--teal);
  }
  .nav__right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--white);
    font-size: 0.85rem;
  }
  .lang a {
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.2s ease;
  }
  .lang a:hover {
    color: var(--white);
  }
  .lang a[aria-current='true'] {
    color: var(--white);
    font-weight: 700;
  }
  .nav__cta {
    display: inline-flex;
    align-items: center;
    background: var(--white);
    color: var(--ink);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-pill);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .nav__cta:hover {
    background: var(--teal);
    color: var(--white);
    transform: translateY(-1px);
  }
  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 0.5rem 0.7rem;
  }
  .burger span {
    width: 26px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .nav[data-open] .burger span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav[data-open] .burger span:nth-child(2) {
    opacity: 0;
  }
  .nav[data-open] .burger span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 900px) {
    .burger {
      display: flex;
    }
    .nav__menu {
      position: absolute;
      inset: calc(100% + 0.6rem) 0 auto 0;
      flex-direction: column;
      align-items: stretch;
      gap: 1.25rem;
      background: rgba(12, 13, 14, 0.92);
      -webkit-backdrop-filter: blur(16px);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      padding: 1.5rem;
      transform: translateY(-10px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }
    .nav[data-open] .nav__menu {
      transform: none;
      opacity: 1;
      pointer-events: auto;
    }
    .nav__links {
      flex-direction: column;
      gap: 1.1rem;
      align-items: flex-start;
    }
    .nav__right {
      justify-content: space-between;
    }
    .nav__cta {
      flex: 1;
      justify-content: center;
    }
  }
</style>

<script>
  const nav = document.querySelector('[data-nav]');
  const burger = document.querySelector('[data-burger]');
  if (nav && burger) {
    const onScroll = () => nav.classList.toggle('is-solid', window.scrollY > 40);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    burger.addEventListener('click', () => {
      const open = nav.hasAttribute('data-open');
      nav.toggleAttribute('data-open');
      burger.setAttribute('aria-expanded', String(!open));
    });
  }
</script>
