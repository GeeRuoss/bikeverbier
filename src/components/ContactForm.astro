---
import { SITE, type Lang } from '../data/site';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
  // Sujet de la demande (ex. "Demande Teambuilding"), pour s'y retrouver dans la boîte mail.
  subject?: string;
  // Affiche le formulaire dans une carte blanche surélevée.
  card?: boolean;
}
const { lang, subject, card = false } = Astro.props;
const c = t(lang).contact;
// Google Form (voir site.ts) : le script global de Layout.astro intercepte l'envoi et redirige.
const G = SITE.gform;
// Redirection après envoi → page de remerciement à notre marque (selon la langue).
const nextUrl = lang === 'fr' ? '/merci' : '/en/thank-you';
---

<form
  class={`cform ${card ? 'cform--card' : ''}`}
  action={G.action}
  method="POST"
  data-next={nextUrl}
  data-message={G.message}
>
  <!-- Sujet de la page : fusionné dans le message par le script global -->
  {subject && <input type="hidden" name="_context" data-label="Sujet" value={subject} />}
  <!-- Honeypot anti-bot : doit rester vide -->
  <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

  <div class="cform__row">
    <label>
      <span>{c.name}</span>
      <input type="text" name={G.name} required autocomplete="name" />
    </label>
    <label>
      <span>{c.email}</span>
      <input type="email" name={G.email} required autocomplete="email" />
    </label>
  </div>

  <div class="cform__row">
    <label>
      <span>{c.phone}</span>
      <input type="tel" name={G.phone} autocomplete="tel" />
    </label>
    <label>
      <span>{c.request}</span>
      <select name={G.request}>
        <option value=""></option>
        {c.requestOptions.map((o) => <option value={o}>{o}</option>)}
      </select>
    </label>
  </div>

  <label>
    <span>{c.message}</span>
    <textarea name={G.message} rows="5" required></textarea>
  </label>

  <button type="submit" class="btn btn--dark cform__submit">
    <span>{c.submit}</span>
    <span class="btn__dot" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </button>
</form>
<!-- styles .cform : dans global.css (partagés avec les formulaires inline des pages) -->
