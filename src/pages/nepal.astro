---
import Layout from '../layouts/Layout.astro';
import { IMG } from '../data/images';
import { SITE } from '../data/site';

const lang = 'fr' as const;
const action = `https://formsubmit.co/${SITE.contactEmail}`;

const atouts = [
  ['Vivez la vallée la plus profonde du monde.', 'Entourée de deux sommets de 8000 m, la vallée du Mustang est la plus profonde du monde.'],
  ['10 jours guidés', 'Vivez l’enduro des rues de Katmandou jusqu’à la vallée du Haut-Mustang.'],
  ['Shuttle privé', 'Découvrez l’accueil chaleureux de jeunes équipes népalaises dynamiques.'],
];
---

<Layout
  lang={lang}
  routeKey="nepal"
  title="Voyage Enduro VTT au Népal – 10 Jours avec Bikeverbier.ch"
  description="Roulez l'enduro au Népal, des rues de Katmandou à la vallée du Haut-Mustang. Un pays magique façonné par la culture locale, les paysages himalayens et des vallées profondes, à travers une aventure VTT d'altitude unique."
  ogImage={IMG.ogNepal}
>
  <section class="hero">
    <img class="hero__bg" src={IMG.heroNepal} alt="Enduro VTT au Mustang, Népal" />
    <div class="hero__inner container">
      <p class="eyebrow" style="color:#fff">Bienvenue au paradis</p>
      <h1 class="h1" data-wipe>10 jours d'enduro à <span class="teal">Mustang, Népal</span></h1>
      <p class="lead">Une culture locale dans une terre véritablement magique.</p>
    </div>
  </section>

  <div class="sheet">
    <section class="section container">
      <p class="lead measure">Roulez l'enduro au Népal, des rues de Katmandou à la vallée du Haut-Mustang. Découvrez un pays magique façonné par la culture locale, les paysages himalayens et des vallées profondes, à travers une aventure VTT d'altitude unique.</p>
    </section>

    <section class="section section--alt">
      <div class="container feature-grid">
        {atouts.map(([t, d]) => (
          <div class="feature" data-reveal>
            <h2 class="h3 teal">{t}</h2>
            <p style="color:var(--gray-text)">{d}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section container">
      <div class="gallery" data-reveal>
        <img src={IMG.nepalMustang} alt="Vallée du Mustang, Népal" loading="lazy" />
        <img src={IMG.nepalShuttle} alt="Shuttle privé au Népal" loading="lazy" />
        <img src={IMG.nepalDays} alt="10 jours guidés au Népal" loading="lazy" />
        {IMG.nepalGallery.map((src) => <img src={src} alt="Enduro VTT au Népal" loading="lazy" />)}
      </div>
    </section>

    <section class="section container">
      <p class="eyebrow">Prix & période</p>
      <h2 class="h2">Octobre – Novembre</h2>
      <p class="lead measure" style="margin-top:1rem">Les tarifs sont sur demande, selon la taille du groupe. Nous faisons de notre mieux pour répondre à vos attentes.</p>
    </section>

    <section class="section section--alt">
      <div class="container">
        <p class="eyebrow">Demande</p>
        <h2 class="h2" style="margin-bottom:1rem">Écrivez-nous</h2>
        <p class="measure" style="margin-bottom:2rem; color:var(--gray-text)">Pour répondre à vos attentes, écrivez-nous et nous ferons de notre mieux pour vous.</p>

        <form class="cform" action={action} method="POST">
          <input type="hidden" name="_subject" value="Demande Nepal — Bikeverbier.ch" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
          <div class="cform__row">
            <label><span>Nom</span><input type="text" name="name" required /></label>
            <label><span>Email</span><input type="email" name="email" required /></label>
          </div>
          <div class="cform__row">
            <label><span>Téléphone</span><input type="tel" name="phone" /></label>
            <label><span>Nombre de riders</span>
              <select name="riders">{['1','2','3','4','5','6','7','8','9','Plus'].map((n) => <option>{n}</option>)}</select>
            </label>
          </div>
          <label><span>Message</span><textarea name="message" rows="5"></textarea></label>
          <button type="submit" class="btn btn--dark cform__submit"><span>Envoyer</span><span class="btn__dot" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span></button>
        </form>
      </div>
    </section>

    <section class="section container center">
      <p class="eyebrow">Photos : Soren Rickards</p>
    </section>
  </div>
</Layout>
