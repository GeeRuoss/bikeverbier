---
import Layout from '../layouts/Layout.astro';
import CtaButton from '../components/CtaButton.astro';
import CallLink from '../components/CallLink.astro';
import ContactForm from '../components/ContactForm.astro';
import Icon from '../components/Icon.astro';
import { IMG } from '../data/images';

const lang = 'fr' as const;
const formUrl = '/docs/formulaire-entreprise.pdf';

const gere = [
  { icon: 'calendar', text: "Planification d'un tour adapté au groupe" },
  { icon: 'bike', text: 'Réservation des E-bikes auprès de nos partenaires' },
  { icon: 'users', text: 'Coordination avec votre responsable' },
  { icon: 'utensils', text: 'Réservation des restaurants et apéritifs' },
];

// ⚠ Réponses FAQ à RÉCUPÉRER auprès de Guillermo (accordéon, non visible dans le HTML Framer).
const faq = [
  'Faut-il avoir un bon niveau en VTT pour participer ?',
  "Fournissez-vous les e-bikes et l'équipement nécessaire ?",
  'Proposez-vous des formules tout compris avec repas et activités ?',
  'Peut-on organiser une sortie pour un grand groupe ?',
  'Comment se passe la coordination avec notre entreprise ?',
  'La sortie est-elle maintenue en cas de mauvais temps ?',
];
---

<Layout
  lang={lang}
  routeKey="entreprise"
  title="Team Building VTT à Verbier | Bike Verbier"
  description="Guide VTT à Verbier avec des locaux : sorties E-bike, enduro, rando gourmande et semaine guidée en chalet. Sentiers secrets du Valais avec des guides nés à Verbier."
  ogImage={IMG.heroEntreprise}
>
  <section class="hero">
    <img class="hero__bg" src={IMG.heroEntreprise} alt="Sortie d'entreprise en VTT à Verbier" />
    <div class="hero__inner container">
      <p class="eyebrow" style="color:#fff">Teambuilding</p>
      <h1 class="h1" data-wipe>On s'occupe de tout, <span class="teal">vous profitez</span>.</h1>
      <p class="lead">Faites respirer votre équipe, vivez une journée hors du temps à deux pas de chez vous.</p>
      <div class="hero-actions"><CtaButton href="#contact" label="Organiser une sortie" variant="light" /><CallLink /></div>
    </div>
  </section>

  <div class="sheet">
    <section class="section container">
      <article class="card">
        <img class="card__img" src={IMG.contactVisual} alt="Sortie d'entreprise à Verbier" loading="lazy" data-reveal="left" />
        <div class="card__body" data-reveal>
          <p class="eyebrow">Ce qu'on gère</p>
          <h2 class="h2">Une journée <span class="teal">clé en main</span></h2>
          <ul class="icon-list">
            {gere.map((g) => (
              <li><span class="icon-badge icon-badge--sm"><Icon name={g.icon} size={20} /></span>{g.text}</li>
            ))}
          </ul>
        </div>
      </article>
    </section>

    <section class="section section--alt">
      <div class="container">
        <article class="card card--reverse">
          <img class="card__img" src={IMG.entrepriseForm} alt="Formulaire sortie d'entreprise" loading="lazy" data-reveal="right" />
          <div class="card__body" data-reveal>
            <p class="eyebrow">Formulaire</p>
            <h2 class="h2">Téléchargez le <span class="teal">formulaire</span></h2>
            <p style="color:var(--gray-text)">Remplissez-le et renvoyez-le nous : on s'occupe du reste. Tout est prêt pour organiser votre journée d'équipe.</p>
            <CtaButton href={formUrl} label="Télécharger le PDF" variant="dark" external />
          </div>
        </article>
      </div>
    </section>

    <section class="section container">
      <p class="eyebrow">Questions ?</p>
      <h2 class="h2" style="margin-bottom:1.5rem">FAQ</h2>
      <div class="faq">
        {
          faq.map((q) => (
            <details>
              <summary>{q}</summary>
              <p>Réponse à compléter, à récupérer auprès de Guillermo.</p>
            </details>
          ))
        }
      </div>
    </section>

    <section class="section section--alt" id="contact">
      <div class="container">
        <p class="eyebrow">Contact</p>
        <h2 class="h2" style="margin-bottom:1.5rem">Une demande pour votre équipe ?</h2>
        <ContactForm lang={lang} subject="Demande Teambuilding · Bikeverbier.ch" card />
      </div>
    </section>
  </div>
</Layout>
