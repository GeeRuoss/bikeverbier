---
import Layout from '../../layouts/Layout.astro';
import CtaButton from '../../components/CtaButton.astro';
import CallLink from '../../components/CallLink.astro';
import Icon from '../../components/Icon.astro';
import { IMG } from '../../data/images';
import { SITE } from '../../data/site';

const lang = 'en' as const;

// CHF prices, IDENTICAL to FR (do not reproduce the Framer auto-translation bug).
const rows = [
  ['1 person', '320.-', '550.-'],
  ['2 people', '195.-', '290.-'],
  ['3 people', '160.-', '220.-'],
  ['4 people', '120.-', '175.-'],
  ['5 people', '95.-', '145.-'],
  ['6 people', '80.-', '120.-'],
];

const features = [
  {
    img: IMG.cardGuide,
    icon: 'pin',
    eyebrow: 'Local guides',
    title: 'Born in Verbier, we know every trail',
    desc: "We don't follow a route on a map, we share the trails of our childhood. From secret singletracks to the panoramic descents of Valais, every ride is a real encounter with the land and its hidden spots.",
  },
  {
    img: IMG.welcome,
    icon: 'leaf',
    eyebrow: 'Respect & enjoyment',
    title: 'At your pace, respecting the mountain',
    desc: 'Beginner or seasoned rider, on an e-bike or enduro, we adapt the terrain and tempo to your level. We ride clean and respect the trails and nature, so the fun lasts, ride after ride.',
  },
];
---

<Layout
  lang={lang}
  routeKey="guide"
  title="Mountain Biking Guide in Verbier | E-bike & Enduro Tours with locals | Bike Verbier"
  description="The best mountain biking guide in Verbier: guided tours and private coaching with guides born in Verbier. E-bike or enduro, all levels. Secret Valais trails, local culture, technique and enjoyment. Rental and organisation included."
  ogImage={IMG.heroGuide}
>
  <section class="hero">
    <img class="hero__bg" src={IMG.heroGuide} alt="Guided mountain bike tour in Verbier with a local guide" />
    <div class="hero__inner container">
      <p class="eyebrow" style="color:#fff">Private guide · Gourmet hike</p>
      <h1 class="h1" data-wipe>Discover the most beautiful <span class="teal">trails of Verbier</span>!</h1>
      <p class="lead">Enjoy the clean air of Verbier at your own pace, with local guides.</p>
      <div class="hero-actions"><CtaButton href={SITE.whatsapp} label="Let's get started!" variant="light" external /><CallLink /></div>
    </div>
  </section>

  <div class="sheet">
    <section class="section container center">
      <p class="eyebrow">Mountain biking guide Verbier</p>
      <h2 class="h2">The <span class="teal">locals'</span> Verbier, on two wheels</h2>
      <p class="lead measure" style="margin:1.25rem auto 0">
        Born and raised in Verbier, we know every trail in Valais, from secret paths to breathtaking descents. On an e-bike or enduro, for beginners and experts alike, we share our mountains with respect and enjoyment.
      </p>
    </section>

    <section class="section container">
      <div class="cards">
        {
          features.map((f, i) => (
            <article class={`card ${i % 2 === 1 ? 'card--reverse' : ''}`}>
              <img class="card__img" src={f.img} alt={f.title} loading="lazy" data-reveal={i % 2 === 1 ? 'right' : 'left'} />
              <div class="card__body" data-reveal>
                <span class="icon-badge icon-badge--lg"><Icon name={f.icon} size={30} /></span>
                <p class="eyebrow">{f.eyebrow}</p>
                <h2 class="h3 teal">{f.title}</h2>
                <p style="color:var(--gray-text)">{f.desc}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <p class="eyebrow">Prices</p>
        <h2 class="h2">Drive at your <span class="teal">level</span>!</h2>
        <p class="lead measure" style="margin-top:.5rem">Price per person, in CHF. The bigger the group, the cheaper.</p>

        <div style="overflow-x:auto; margin-top:2rem">
          <table class="price-table">
            <thead>
              <tr><th>People</th><th>Half-Day</th><th>Full Day</th></tr>
            </thead>
            <tbody>
              {rows.map((r) => <tr><td>{r[0]}</td><td>{r[1]}</td><td>{r[2]}</td></tr>)}
            </tbody>
          </table>
        </div>

        <ul class="icon-list" style="margin-top:1.75rem">
          <li><span class="icon-badge icon-badge--sm"><Icon name="bike" size={20} /></span>E-Bike rental: 120.- full day · 95.- half day</li>
          <li><span class="icon-badge icon-badge--sm"><Icon name="shield" size={20} /></span>Helmet: <strong style="margin-left:.3rem">offered</strong></li>
        </ul>

        <div style="margin-top:2rem"><CtaButton href={SITE.whatsapp} label="Let's get started!" variant="dark" external /></div>
      </div>
    </section>

    <section class="section container">
      <div class="measure center" style="margin-inline:auto">
        <div style="display:flex; justify-content:center; gap:.25rem; color:#f5b301; margin-bottom:1rem">
          {[0, 1, 2, 3, 4].map(() => <Icon name="star" size={26} class="star-filled" />)}
        </div>
        <blockquote class="lead">“An incredible experience! A professional, passionate, and very patient guide. Whether you are a beginner or experienced, I highly recommend this course to perfect the basics, build confidence, and fully enjoy your bike outings. And the fact that he knows the region perfectly is a great asset.”</blockquote>
        <p style="margin-top:1rem; color:var(--gray-text)">Norma, Verbier</p>
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <article class="card card--reverse">
          <img class="card__img" src={IMG.guideVideos} alt="Technical mountain biking videos" loading="lazy" data-reveal="right" />
          <div class="card__body" data-reveal>
            <p class="eyebrow">Lessons &amp; technique</p>
            <h2 class="h3">The pleasure of mountain biking comes from <span class="teal">mastery</span>.</h2>
            <p style="color:var(--gray-text)">Adult or child, <strong>private lessons</strong> are available upon request, to progress at your own pace with personalised support. Meanwhile, discover a selection of useful <strong>technical videos</strong> to refine your driving skills.</p>
            <CtaButton href="https://www.mobilesport.ch/vtt/mtb-f/" label="Watch the Videos" variant="dark" external />
          </div>
        </article>
      </div>
    </section>
  </div>
</Layout>
