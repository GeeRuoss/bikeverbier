---
import Layout from '../../layouts/Layout.astro';
import CtaButton from '../../components/CtaButton.astro';
import CallLink from '../../components/CallLink.astro';
import ContactForm from '../../components/ContactForm.astro';
import ContactBand from '../../components/ContactBand.astro';
import Icon from '../../components/Icon.astro';
import { IMG } from '../../data/images';

const lang = 'en' as const;
const formUrl = '/docs/formulaire-entreprise.pdf';

const gere = [
  { icon: 'calendar', text: 'Planning a tour tailored for the group' },
  { icon: 'bike', text: 'Reservation of E-bikes with our partners' },
  { icon: 'users', text: 'Coordination with your supervisor' },
  { icon: 'utensils', text: 'Restaurant reservations and appetizers' },
];

const faq = [
  {
    q: 'Is a good level of mountain biking required to participate?',
    a: 'Not at all. The outings are open to all levels, beginners included. Thanks to e-bikes, everyone goes at their own pace, with no pressure. The goal is to share a friendly moment out in nature, not to race.',
  },
  {
    q: 'Do you provide e-bikes and the necessary equipment?',
    a: 'Yes. We book quality e-bikes for you with our local partners. Helmets and other gear can be provided on request. You simply come with suitable outdoor clothing, we take care of the rest.',
  },
  {
    q: 'Do you offer all-inclusive packages with meals and activities?',
    a: 'Yes, we design turnkey packages: aperitifs on the terrace, mountain-top meals, tastings of local produce or even side activities. Every outing is designed as a complete, tailor-made experience.',
  },
  {
    q: 'Is it possible to arrange an outing for a large group?',
    a: 'Absolutely. We can host groups of all sizes, including 20 people or more. The logistics are adapted to ensure comfort, safety and flow, even for large teams. A second guide is sometimes needed.',
  },
  {
    q: 'How is the coordination with our company managed?',
    a: 'A single point of contact is assigned to your company to make sharing information and handling the details easy. We stay available and responsive at every step, so everything runs smoothly.',
  },
  {
    q: 'Is the excursion still on in case of bad weather?',
    a: 'In case of bad weather, several options are considered: adapting the route, changing the date, or switching to an alternative activity. Our priority remains the safety and enjoyment of every participant.',
  },
];
---

<Layout
  lang={lang}
  routeKey="entreprise"
  title="Mountain Biking Team Building in Verbier | Bike Verbier"
  description="Day trips, exploration of local heritage, a week in a chalet with a private guide and lift pass. Local trails, authentic and bespoke alpine experience."
  ogImage={IMG.heroEntreprise}
>
  <section class="hero">
    <img class="hero__bg" src={IMG.heroEntreprise} alt="Corporate mountain biking outing in Verbier" />
    <div class="hero__inner container">
      <p class="eyebrow" style="color:#fff">Teambuilding</p>
      <h1 class="h1" data-wipe>We take care of everything, <span class="teal">you enjoy</span>.</h1>
      <p class="lead">Let your team breathe, experience a timeless day right on your doorstep.</p>
      <div class="hero-actions"><CtaButton href="#contact" label="Plan an outing" variant="light" /><CallLink /></div>
    </div>
  </section>

  <div class="sheet">
    <section class="section container">
      <article class="card">
        <img class="card__img" src={IMG.contactVisual} alt="Corporate outing in Verbier" loading="lazy" data-reveal="left" />
        <div class="card__body" data-reveal>
          <p class="eyebrow">What we handle</p>
          <h2 class="h2">A <span class="teal">turnkey</span> day</h2>
          <ul class="icon-list">
            {gere.map((g) => (
              <li><span class="icon-badge icon-badge--sm"><Icon name={g.icon} size={20} /></span>{g.text}</li>
            ))}
          </ul>
        </div>
      </article>
    </section>

    <section class="section section--alt">
      <div class="container">
        <article class="card card--reverse">
          <img class="card__img" src={IMG.entrepriseForm} alt="Corporate outing form" loading="lazy" data-reveal="right" />
          <div class="card__body" data-reveal>
            <p class="eyebrow">Form</p>
            <h2 class="h2">Download the <span class="teal">form</span></h2>
            <p style="color:var(--gray-text)">Fill it in and send it back to us, we take care of the rest. Everything is ready to organise your team day.</p>
            <CtaButton href={formUrl} label="Download the PDF" variant="dark" external />
          </div>
        </article>
      </div>
    </section>

    <section class="section container">
      <p class="eyebrow">Inquiries?</p>
      <h2 class="h2" style="margin-bottom:1.5rem">FAQ</h2>
      <div class="faq">
        {
          faq.map((item) => (
            <details>
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))
        }
      </div>
    </section>

    <ContactBand
      lang={lang}
      eyebrow="Contact"
      title="An inquiry for your team?"
      lead="Tell us what you have in mind, we take care of all the organisation."
      id="contact"
    >
      <ContactForm lang={lang} subject="Teambuilding inquiry · Bikeverbier.ch" card />
    </ContactBand>
  </div>
</Layout>
