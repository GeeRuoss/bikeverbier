---
import Layout from '../../layouts/Layout.astro';
import CtaButton from '../../components/CtaButton.astro';
import CallLink from '../../components/CallLink.astro';
import ContactBand from '../../components/ContactBand.astro';
import { IMG } from '../../data/images';
import { SITE } from '../../data/site';

const lang = 'en' as const;

const atouts = [
  ['Full chalet experience.', '6 nights in a well-equipped mountain chalet for small groups. 1 minute from the lift.'],
  ['5 guided days', '5 days of epic riding with a Swiss Cycling certified local guide.'],
  ['Lift pass included.', '5-day lift pass and custom tours adapted to the group.'],
];

const tarifs = [
  ['9 riders', "CHF 1'290.-"],
  ['8 riders', "CHF 1'390.-"],
  ['7 riders', "CHF 1'540.-"],
  ['6 riders', "CHF 1'760.-"],
  ['5 riders', "CHF 1'990.-"],
];

// ⚠ 2026 season dates to CONFIRM with Guillermo.
const semaines = [
  'Aug 3 to 9', 'Aug 10 to 16', 'Aug 17 to 23', 'Aug 24 to 30',
  'Aug 31 to Sep 6', 'Sep 7 to 13', 'Sep 14 to 20', 'Sep 21 to 27',
  'Sep 28 to Oct 4', 'Oct 5 to 11', 'Oct 12 to 18', 'Oct 19 to 25',
];
// Google Form (see site.ts): the global script in Layout.astro intercepts submit and redirects.
const G = SITE.gform;
---

<Layout
  lang={lang}
  routeKey="semaine"
  title="Guided MTB Week + Chalet in Verbier | Bikeverbier.ch"
  description="Guided 1-week riding trips in Verbier with chalet accommodation, local guide, small groups, and breathtaking Valais scenery. Organised by Bikeverbier.ch."
  ogImage={IMG.heroSemaine}
>
  <section class="hero">
    <img class="hero__bg" src={IMG.heroSemaine} alt="Guided MTB week with chalet in Verbier" />
    <div class="hero__inner container">
      <p class="eyebrow" style="color:#fff">Welcome to paradise</p>
      <h1 class="h1" data-wipe>1 Riding Week in Verbier with <span class="teal">Local guide</span></h1>
      <p class="lead">Chalet Stay, Local guide, Lift.</p>
      <div class="hero-actions"><CtaButton href="#reservation" label="Let's go!" variant="light" /><CallLink /></div>
    </div>
  </section>

  <div class="sheet">
    <section class="section section--intro container center">
      <p class="eyebrow">Guided MTB week in Verbier</p>
      <h2 class="h2">A week of riding, <span class="teal">all sorted</span></h2>
      <p class="lead measure" style="margin:1.25rem auto 0">
        Private chalet 30 seconds from the lift, certified Swiss Cycling local guide, lift pass included and Valais trails tailored to your group. All you have to do is ride, we take care of the rest.
      </p>
    </section>

    <section class="section container">
      <div class="feature-grid">
        {atouts.map(([t, d]) => (
          <div class="feature" data-reveal>
            <h2 class="h3 teal">{t}</h2>
            <p style="color:var(--gray-text)">{d}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <p class="eyebrow">Price per person</p>
        <h2 class="h2">The more, <span class="teal">the merrier</span></h2>
        <p class="measure" style="margin:1rem 0 2rem; color:var(--gray-text)">Included: 6 nights in a private chalet (30 sec. from the Médran lift) · 5 days guided by a certified Swiss Cycling guide · lift pass or shuttle on all riding days.</p>
        <div style="overflow-x:auto">
          <table class="price-table">
            <thead><tr><th>Riders</th><th>Price / person</th></tr></thead>
            <tbody>{tarifs.map((r) => <tr><td>{r[0]}</td><td>{r[1]}</td></tr>)}</tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="section container">
      <div class="gallery" data-reveal>
        <img src={IMG.semaineChalet} alt="Mountain chalet in Verbier" loading="lazy" />
        <img src={IMG.semaineLift} alt="Lift pass" loading="lazy" />
        {IMG.semaineGallery.map((src) => <img src={src} alt="MTB week in Verbier" loading="lazy" />)}
      </div>
    </section>

    <ContactBand lang={lang} eyebrow="Reservation" title="Request your week" lead="Fill out the form to request your preferred week. We'll get back to you shortly to confirm the details. See you on the trails!" id="reservation">
      <form class="cform cform--card" action={G.action} method="POST" data-next="/en/thank-you" data-message={G.message}>
        <input type="hidden" name={G.request} value="Week + Chalet reservation" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="cform__row">
          <label><span>Name</span><input type="text" name={G.name} required /></label>
          <label><span>Email</span><input type="email" name={G.email} required /></label>
        </div>
        <div class="cform__row">
          <label><span>Phone Number</span><input type="tel" name={G.phone} /></label>
          <label><span>Number of riders</span>
            <select name="riders" data-label="Number of riders">{['1','2','3','4','5','6','7','8','9','More'].map((n) => <option>{n}</option>)}</select>
          </label>
        </div>
        <div class="cform__row">
          <label><span>Number of couples</span>
            <select name="couples" data-label="Number of couples">{['0','1','2','3','4'].map((n) => <option>{n}</option>)}</select>
          </label>
          <label><span>Preferred week</span>
            <select name="week" data-label="Preferred week">{semaines.map((s) => <option>{s}</option>)}</select>
          </label>
        </div>
        <label><span>Message</span><textarea name={G.message} rows="5"></textarea></label>
        <button type="submit" class="btn btn--dark cform__submit"><span>Reserve Now</span><span class="btn__dot" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span></button>
      </form>
    </ContactBand>
  </div>
</Layout>
