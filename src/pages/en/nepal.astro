---
import Layout from '../../layouts/Layout.astro';
import CtaButton from '../../components/CtaButton.astro';
import CallLink from '../../components/CallLink.astro';
import ContactBand from '../../components/ContactBand.astro';
import Icon from '../../components/Icon.astro';
import { IMG } from '../../data/images';
import { SITE } from '../../data/site';

const lang = 'en' as const;
// Google Form (see site.ts): the global script in Layout.astro intercepts submit and redirects.
const G = SITE.gform;

const features = [
  {
    img: IMG.nepalMustang,
    icon: 'mountain',
    eyebrow: 'The valley',
    title: "The world's deepest valley",
    desc: 'Surrounded by two 8,000-meter peaks, the Mustang Valley is the deepest in the world. Breathtaking Himalayan landscapes, ridden on two wheels.',
  },
  {
    img: IMG.nepalDays,
    icon: 'route',
    eyebrow: '10 guided days',
    title: 'From Kathmandu to Upper Mustang',
    desc: 'Experience enduro from the busy streets of Kathmandu to the remote trails of Upper Mustang, guided from start to finish.',
  },
  {
    img: IMG.nepalShuttle,
    icon: 'van',
    eyebrow: 'Private shuttle',
    title: 'A warm Nepali welcome',
    desc: 'Experience the welcome of young, dynamic Nepali teams. Private shuttle, logistics handled, all you have to do is ride.',
  },
];
---

<Layout
  lang={lang}
  routeKey="nepal"
  title="Enduro MTB Trip in Nepal, 10 Days with Bikeverbier.ch"
  description="Ride enduro in Nepal, from the streets of Kathmandu to the Upper Mustang Valley. Discover a magical country shaped by local culture, Himalayan landscapes and deep valleys, through a unique high-altitude mountain biking adventure."
  ogImage={IMG.ogNepal}
>
  <section class="hero">
    <img class="hero__bg" src={IMG.heroNepal} alt="Enduro mountain biking in Mustang, Nepal" />
    <div class="hero__inner container">
      <p class="eyebrow" style="color:#fff">The journey of a lifetime</p>
      <h1 class="h1" data-wipe>10 days of enduro in <span class="teal">Mustang, Nepal</span></h1>
      <p class="lead">Local culture in a truly magical land.</p>
      <div class="hero-actions"><CtaButton href="#demande" label="Book the adventure" variant="light" /><CallLink /></div>
    </div>
  </section>

  <div class="sheet">
    <section class="section section--intro container center">
      <p class="lead measure" style="margin-inline:auto">
        Ride enduro in Nepal, from the streets of Kathmandu to the Upper Mustang Valley. Discover a magical country shaped by local culture, Himalayan landscapes and deep valleys, a unique high-altitude mountain biking adventure.
      </p>
    </section>

    <section class="section container">
      <div class="cards">
        {
          features.map((f, i) => (
            <article class={`card ${i % 2 === 1 ? 'card--reverse' : ''}`}>
              <img class="card__img" src={f.img} alt={f.title} loading="lazy" data-reveal={i % 2 === 1 ? 'right' : 'left'} />
              <div class="card__body" data-reveal>
                <span class="icon-badge icon-badge--lg"><Icon name={f.icon} size={30} /></span>
                <p class="eyebrow">{f.eyebrow}</p>
                <h2 class="h3 teal">{f.title}</h2>
                <p style="color:var(--gray-text)">{f.desc}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="container center">
        <p class="eyebrow">Video</p>
        <h2 class="h2">The adventure in <span class="teal">motion</span></h2>
        <div class="video-embed" data-reveal>
          <iframe
            src="https://www.youtube-nocookie.com/embed/4ukFqHzGKEI"
            title="Enduro mountain bike trip in Nepal · Bikeverbier.ch"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <p class="eyebrow center">Gallery</p>
        <div class="gallery" style="margin-top:2rem" data-reveal>
          {IMG.nepalGallery.map((src) => <img src={src} alt="Enduro mountain biking in Nepal" loading="lazy" />)}
        </div>
        <p class="center" style="margin-top:1.5rem; color:var(--gray-soft); font-size:.85rem">Photos: Soren Rickards</p>
      </div>
    </section>

    <section class="section section--dark">
      <div class="container center">
        <p class="eyebrow">Pricing &amp; period</p>
        <h2 class="h2">October to <span class="teal">November</span></h2>
        <p class="lead measure" style="margin:1.25rem auto 0">
          Pricing is on demand, depending on group size. We do our best to match your expectations.
        </p>
        <div style="margin-top:2rem; display:flex; justify-content:center">
          <CtaButton href="#demande" label="Request a quote" variant="teal" />
        </div>
      </div>
    </section>

    <ContactBand lang={lang} eyebrow="Inquiry" title="Write to us" lead="To match your expectations, write to us and we'll do our best for you." id="demande">
      <form class="cform cform--card" action={G.action} method="POST" data-next="/en/thank-you" data-message={G.message}>
          <input type="hidden" name={G.request} value="Nepal inquiry" />
          <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
          <div class="cform__row">
            <label><span>Name</span><input type="text" name={G.name} required /></label>
            <label><span>Email</span><input type="email" name={G.email} required /></label>
          </div>
          <div class="cform__row">
            <label><span>Phone Number</span><input type="tel" name={G.phone} /></label>
            <label><span>Number of riders</span>
              <select name="riders" data-label="Number of riders">{['1','2','3','4','5','6','7','8','9','More'].map((n) => <option>{n}</option>)}</select>
            </label>
          </div>
          <label><span>Message</span><textarea name={G.message} rows="5"></textarea></label>
          <button type="submit" class="btn btn--dark cform__submit"><span>Send</span><span class="btn__dot" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span></button>
        </form>
    </ContactBand>
  </div>
</Layout>
