---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import CallLink from '../../components/CallLink.astro';
import { IMG, BADGES } from '../../data/images';

const lang = 'en' as const;

const guides = [
  {
    img: IMG.guideGuillermo,
    name: 'Guillermo Ruoss',
    role: 'Director · Swiss Cycling guide',
    bio: 'Director of Bikeverbier.ch, certified by Swiss Cycling and freelance graphic designer, Guillermo was born in Verbier in 2001. Curious and passionate about meeting people, he created Bikeverbier to share his love of the mountains with people from all walks of life.',
    quote: 'There exists a hidden Verbier.',
    badges: [{ src: BADGES.swissCycling, label: 'Swiss Cycling Guide' }],
  },
  {
    img: IMG.guideJoshua,
    name: 'Joshua Ruoss',
    role: 'Mountain guide · Tandem pilot',
    bio: 'Certified mountain guide and enthusiastic paragliding pilot, "Josh" Ruoss was born in Verbier in 1998. Rooted in the Valais Alps, he now divides his time between the summits, the trails and the skies, eager to pass on his passion and his view of the mountains to those who join him.',
    badges: [{ src: BADGES.mountainGuide, label: 'Mountain guide IVBV / IFMGA / UIAGM' }],
  },
  {
    img: IMG.guideGilles,
    name: 'Gilles Ammann',
    role: 'Tandem pilot',
    bio: 'Director of Flyverbier.ch and a paragliding enthusiast, Gilles Ammann shares his grounding in Verbier between thermal winds and alpine paths. When the sky closes to wings, he hops on his bike to explore the terrain, savouring every climb like a flight in waiting. His sharp eye for the mountains, forged by experience, passes naturally to those he guides through the air.',
    badges: [],
  },
];
---

<Layout
  lang={lang}
  routeKey="contact"
  title="Contact - Bikeverbier.ch"
  description="Day trips, exploration of local heritage, a week in a chalet with a private guide and lift pass. Local trails, authentic and bespoke alpine experience."
>
  <section class="section contact-hero contact-hero--top">
    <div class="container contact-split">
      <div>
        <img class="contact-avatar" src={IMG.guideGuillermo} alt="Bikeverbier guide" loading="lazy" />
        <h1 class="h1" style="color:#fff">Discover Verbier with the locals!</h1>
        <p class="lead" style="margin-top:1.25rem; max-width:42ch">Feel free to call us even for inquiries or advice about the region!</p>
        <p style="margin-top:1.5rem; display:flex; align-items:center; gap:.75rem; flex-wrap:wrap; font-weight:600">We speak <img class="contact-flags" src={IMG.flags} alt="Français, English, Español, Deutsch" /></p>
        <p style="margin-top:1.75rem"><CallLink /></p>
      </div>
      <div>
        <ContactForm lang={lang} subject="Message · Bikeverbier.ch" card />
      </div>
    </div>
  </section>

  <section class="section section--alt" id="guides">
    <div class="container">
      <p class="eyebrow">Meet our guides</p>
      <h2 class="h2" style="margin-bottom:.75rem">All born in <span class="teal">Verbier</span></h2>
      <p class="measure" style="margin-bottom:2.5rem; color:var(--gray-text)">They will expertly guide you along the most beautiful paths and to the finest restaurants.</p>

      <div class="cards">
        {
          guides.map((g) => (
            <article class="card" data-reveal>
              <img class="card__img" src={g.img} alt={g.name} loading="lazy" />
              <div class="card__body">
                <h3 class="h3">{g.name}</h3>
                <p class="eyebrow">{g.role}</p>
                <p style="color:var(--gray-text)">{g.bio}</p>
                {g.badges.length > 0 && (
                  <div class="badges">{g.badges.map((b) => <img src={b.src} alt={b.label} title={b.label} />)}</div>
                )}
                {g.quote && <p class="lead teal">“{g.quote}”</p>}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
