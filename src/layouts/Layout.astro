---
import '@fontsource-variable/inter';
import '../styles/global.css';

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { SITE, ROUTES, type Lang, type RouteKey } from '../data/site';
import { IMG } from '../data/images';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
  routeKey: RouteKey;
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: boolean;
}
const { lang, routeKey, title, description, ogImage = IMG.ogDefault, jsonLd = false } = Astro.props;

const htmlLang = lang === 'fr' ? 'fr-FR' : 'en-GB';
const route = ROUTES.find((r) => r.key === routeKey)!;
const canonical = SITE.domain + route[lang];
// og:image doit être une URL absolue.
const ogImageAbs = ogImage.startsWith('http') ? ogImage : SITE.domain + ogImage;
const frUrl = SITE.domain + route.fr;
const enUrl = SITE.domain + route.en;
const ui = t(lang);

const homeUrl = lang === 'fr' ? SITE.domain + '/' : SITE.domain + '/en/';

// Entité business, riche, partagée sur toutes les pages (@id stable).
const businessLd = {
  '@context': 'https://schema.org',
  '@type': ['SportsActivityLocation', 'LocalBusiness'],
  '@id': SITE.domain + '/#business',
  name: 'Bikeverbier.ch',
  description:
    'Guide VTT local à Verbier (Valais, Suisse) : sorties e-bike et enduro, rando gourmande, semaine guidée en chalet et voyage enduro au Népal. Guides nés à Verbier, certifiés Swiss Cycling, pour tous les niveaux.',
  url: SITE.domain,
  telephone: '+41774506726',
  image: SITE.domain + '/img/og-home.jpg',
  logo: SITE.domain + '/brand/logo-mark.png',
  priceRange: 'CHF 120-1290',
  currenciesAccepted: 'CHF',
  knowsLanguage: ['fr', 'en', 'es', 'de'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Verbier',
    postalCode: '1936',
    addressRegion: 'Valais',
    addressCountry: 'CH',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 46.0979, longitude: 7.227 },
  areaServed: { '@type': 'Place', name: 'Verbier, Val de Bagnes, Valais, Suisse' },
  sameAs: [SITE.instagram],
  makesOffer: [
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Guide privé VTT et rando gourmande', url: SITE.domain + '/guide' } },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Teambuilding et sortie VTT entreprise', url: SITE.domain + '/entreprise' } },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Semaine guidée VTT + chalet', url: SITE.domain + '/semaine-guidechalet' } },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Voyage enduro VTT au Népal', url: SITE.domain + '/nepal' } },
  ],
};

// Fil d'Ariane sur les pages internes.
const breadcrumbLd =
  routeKey === 'home'
    ? null
    : {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: lang === 'fr' ? 'Accueil' : 'Home', item: homeUrl },
          { '@type': 'ListItem', position: 2, name: (ui.nav as Record<string, string>)[routeKey] ?? title, item: canonical },
        ],
      };
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Google tag (gtag.js) — Analytics GA4. Uniquement en prod (pas de pollution depuis le dev). */}
    {import.meta.env.PROD && (
      <>
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-7G9DCF9XTC"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-7G9DCF9XTC');
        </script>
      </>
    )}

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="author" content="Bikeverbier.ch" />
    <meta name="theme-color" content="#54B8B3" />
    <link rel="canonical" href={canonical} />

    <!-- SEO local (Verbier, Valais) -->
    <meta name="geo.region" content="CH-VS" />
    <meta name="geo.placename" content="Verbier" />
    <meta name="geo.position" content="46.0979;7.227" />
    <meta name="ICBM" content="46.0979, 7.227" />

    <!-- hreflang FR / EN / x-default (cf. SEO.md) -->
    <link rel="alternate" hreflang="fr-FR" href={frUrl} />
    <link rel="alternate" hreflang="en-GB" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={frUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Bikeverbier.ch" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:locale" content={htmlLang.replace('-', '_')} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="llms.txt" />

    <!-- Données structurées (Schema.org) sur chaque page -->
    <script type="application/ld+json" set:html={JSON.stringify(businessLd)} />
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
  </head>

  <body>
    <a class="skip-link" href="#main">{ui.skip}</a>
    <Nav lang={lang} routeKey={routeKey} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <WhatsAppButton lang={lang} />

    <script>
      // Reveal au scroll (fade-up). IntersectionObserver vanilla.
      const els = document.querySelectorAll('[data-reveal]');
      if (els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px' }
        );
        els.forEach((el) => io.observe(el));
      }

      // Compteurs animés (montent depuis 0 à l'entrée dans le viewport).
      const counters = document.querySelectorAll<HTMLElement>('[data-count]');
      if (counters.length) {
        const run = (el: HTMLElement) => {
          const target = Number(el.dataset.count || '0');
          const dur = 1400;
          const start = performance.now();
          const step = (now: number) => {
            const p = Math.min((now - start) / dur, 1);
            el.textContent = Math.round(target * (1 - Math.pow(1 - p, 3))).toString();
            if (p < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
        };
        const cio = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                run(e.target as HTMLElement);
                cio.unobserve(e.target);
              }
            }
          },
          { threshold: 0.4 }
        );
        counters.forEach((el) => cio.observe(el));
      }
    </script>
  </body>
</html>
